# ── Home Assistant ─────────────────────────────────────────────────────────────
# Full URL to your HA instance (no trailing slash)
VITE_HA_URL=http://192.168.1.x:8123

# Long-lived access token from HA → Profile → Security → Long-lived access tokens
VITE_HA_TOKEN=your_long_lived_access_token_here

# ── Pi-hole ────────────────────────────────────────────────────────────────────
# Pi-hole admin password (v6 API auth)
VITE_PIHOLE_PASSWORD=your_pihole_password_here

# Pi-hole host:port for the nginx proxy (no http://)
PIHOLE_HOST=192.168.1.x:8181

# ── Netdata ────────────────────────────────────────────────────────────────────
# Netdata host:port for the nginx proxy (no http://)
NETDATA_HOST=192.168.1.x:19999
